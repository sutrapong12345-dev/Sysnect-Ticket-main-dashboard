# ============================================================
# ตัวอย่าง ENV — คัดลอกเป็น .env แล้วใส่ค่าจริง (อย่า commit .env ขึ้น Git)
#   copy .env.example .env
# ⚠️ ค่าด้านล่างเป็น placeholder ทั้งหมด — เปลี่ยนเป็นค่าจริงก่อนใช้งาน
# ============================================================

# ===== PostgreSQL =====
DB_HOST=localhost
DB_PORT=5432
DB_USER=sysnect
DB_PASSWORD=__CHANGE_ME__strong_db_password
DB_NAME=ticket_database

# ===== Security =====
# origin ที่อนุญาตให้เรียก API (คั่นด้วย ,) — เลิกใช้ * เพื่อความปลอดภัย
ALLOWED_ORIGINS=https://your-dashboard-domain.example,http://localhost:3000,http://127.0.0.1:3000
# ตั้ง token เพื่อให้สั่ง POST /api/sync จากภายนอกได้ (ส่ง header X-Sync-Token)
# ถ้าเว้นว่าง: /api/sync เรียกได้เฉพาะ localhost เท่านั้น
SYNC_TOKEN=

# ===== Delta Sync =====
N8N_WEBHOOK=https://n8n.example.com/webhook/__CHANGE_ME__webhook_id
BACKFILL_DAYS=120          # ดึงย้อนหลังกี่วันตอน DB ว่าง (ครั้งแรก)
SYNC_INTERVAL_MS=300000    # รอบ sync อัตโนมัติ (300000 = 5 นาที)
N8N_TIMEOUT=45000

# ===== GLPI (ช่องทางสำรองฝั่ง server เท่านั้น — token ไม่หลุดมาหน้าเว็บ) =====
GLPI_BASE_URL=https://glpi.example.com/apirest.php
GLPI_USER=__CHANGE_ME__glpi_user
GLPI_PASS=__CHANGE_ME__glpi_password
GLPI_APP_TOKEN=__CHANGE_ME__glpi_app_token
GLPI_TIMEOUT=30000
GLPI_PAGE_SIZE=1000
